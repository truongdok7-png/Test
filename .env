# Token của bot Discord (lấy từ Discord Developer Portal)
TOKEN=

# ID của kênh sẽ gửi tin nhắn tự động (bật chế độ Developer Mode, chuột phải vào kênh -> Copy ID)
AUTO_CHANNEL_ID=1450562451979370676
# Nội dung tin nhắn tự động (có thể dùng emoji, mention user bằng <@ID>)
AUTO_MESSAGE=Chào https://cdn.discordapp.com/emojis/1486606476373131264.webp?size=128&animated=true

# Khoảng thời gian gửi tin nhắn tự động (đơn vị: mili giây). Ví dụ 60000 = 60 giây
AUTO_INTERVAL=60000
